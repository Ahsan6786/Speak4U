rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Match any document in the 'users' collection
    match /users/{userId} {
      // Allow the user to read and write their own profile document
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Match any document in the 'sessions' sub-collection
      match /sessions/{sessionId} {
        // Allow the user to read and write their own session data
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
